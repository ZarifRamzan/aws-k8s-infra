# ==============================================================================
# .gitignore - AWS Kubernetes Infrastructure (Terraform + Ansible)
# ==============================================================================
# 📌 Purpose: Prevent sensitive data, build artifacts, and local configs 
#            from being committed to version control.
# 📌 Rule of Thumb: If it contains secrets, is auto-generated, or is 
#                  machine-specific → IGNORE IT.
# ==============================================================================

# ==============================================================================
# 🔐 SECRETS & CREDENTIALS (NEVER COMMIT)
# ==============================================================================
# AWS/Environment credentials
.env
.env.local
.env.*.local
*.secret
*.credentials

# SSH Keys - Private keys are HIGH SECURITY RISK
*.pem
*.key
*.ppk
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.pub !*.pub  # Allow public keys (safe to share), block private

# Terraform variables that may contain secrets
# (Keep terraform.tfvars.example for documentation, ignore actual values)
*.auto.tfvars
*.auto.tfvars.json
terraform.tfvars.backup
*.secret.tfvars

# Ansible Vault files (encrypted is OK, unencrypted is not)
*vault*.yml !example*vault.yml
.vault_pass
.vault_password
*.vault_password

# ==============================================================================
# 🗄️ TERRAFORM STATE & ARTIFACTS
# ==============================================================================
# Local working directory (plugins, modules, cache)
.terraform/

# State files - contain infrastructure details & potentially secrets
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info

# Plan files - temporary execution plans
*.tfplan
*.tfplan.json
tfplan

# Crash log files
crash.log
crash.*.log

# Override files (local-only customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==============================================================================
# ⚠️  IMPORTANT: What TO COMMIT for Terraform
# ==============================================================================
# ✅ DO COMMIT:
# - *.tf (all configuration files)
# - .terraform.lock.hcl (provider version lock - ensures reproducibility)
# - terraform.tfvars.example (documentation of required variables)
# - README.md, docs/ (project documentation)

# ==============================================================================
# 🤖 ANSIBLE ARTIFACTS & TEMP FILES
# ==============================================================================
# Retry files (created when playbook fails)
*.retry

# Log files from playbook runs
ansible.log
*.log

# Python cache files (Ansible is Python-based)
__pycache__/
*.py[cod]
*$py.class
*.so

# Galaxy roles (downloaded dependencies - reinstall via requirements.yml)
roles/
!roles/README.md
!roles/requirements.yml

# Inventory files (auto-generated by Terraform, ignore to avoid stale IPs)
inventory.ini
inventory.yml
hosts

# ==============================================================================
# 🐳 DOCKER & CONTAINER ARTIFACTS
# ==============================================================================
# Docker build cache & volumes
.docker/
docker-compose.override.yml

# Container runtime files
*.dockerignore

# ==============================================================================
# 💻 IDE, EDITOR & SYSTEM FILES
# ==============================================================================
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, GoLand, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim/Neovim swap & backup files
*.swp
*.swo
*.swn
*~
*.bak
*.tmp

# Emacs backup files
*#
.#*

# macOS metadata
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail cache
Thumbs.db
ehthumbs.db

# Linux backup files
*~
*.tmp
*.temp

# ==============================================================================
# 🗑️ BUILD & DEPLOYMENT ARTIFACTS
# ==============================================================================
# Compiled binaries (if you ever build Go/Python tools)
*.exe
*.dll
*.so
*.dylib

# Node.js dependencies (if you add a frontend later)
node_modules/
npm-debug.log
yarn-error.log

# Python virtual environments
venv/
env/
.venv/
*.egg-info/
.Python

# ==============================================================================
# 🧪 TEST & DEBUG FILES
# ==============================================================================
# Test coverage reports
coverage/
*.coverage
htmlcov/

# pytest cache
.pytest_cache/

# ==============================================================================
# 📦 ARCHIVES & BACKUPS
# ==============================================================================
# Compressed archives (manual backups should not be versioned)
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# ==============================================================================
# ✅ EXCEPTIONS: Files we WANT to track despite patterns above
# ==============================================================================
# Allow example/placeholder files for documentation
!example.env
!example-vault.yml
!terraform.tfvars.example
!inventory.ini.example

# Allow public SSH keys (safe to share for team onboarding)
!*.pub

# Allow lock file for reproducible provider versions
!.terraform.lock.hcl

# Allow requirements files for dependency management
!roles/requirements.yml
!requirements.txt
!Pipfile
!Pipfile.lock

# ==============================================================================
# 🎯 FINAL REMINDERS
# ==============================================================================
# 🔄 Before committing, always run:
#    git status
#    git add -n .  # Dry-run to see what would be added
#
# 🔐 If you accidentally commit a secret:
#    1. Rotate the credential immediately (AWS keys, SSH keys, passwords)
#    2. Use git filter-branch or BFG Repo-Cleaner to remove from history
#    3. Force push: git push --force-with-lease
#
# 📚 Documentation:
#    - Terraform: https://www.terraform.io/docs/state/sensitive-data.html
#    - Ansible: https://docs.ansible.com/ansible/latest/reference_appendices/config.html
#    - Git: https://git-scm.com/docs/gitignore